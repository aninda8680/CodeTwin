#!/usr/bin/env bash
set -euo pipefail

SELF="$(realpath "${BASH_SOURCE[0]}")"
ROOT="$(cd "$(dirname "$SELF")" && pwd)"
APP="$ROOT/codetwin-cli"
REMOTE_SERVER_DIR="$ROOT/codetwin-remote-server"

if [[ ! -d "$APP" ]]; then
  echo "Error: expected codetwin-cli workspace at: $APP" >&2
  exit 1
fi

if command -v bun >/dev/null 2>&1; then
  BUN="$(command -v bun)"
elif [[ -x "$HOME/.bun/bin/bun" ]]; then
  BUN="$HOME/.bun/bin/bun"
  export PATH="$HOME/.bun/bin:$PATH"
else
  echo "Error: Bun is not installed." >&2
  echo "Install Bun: curl -fsSL https://bun.sh/install | bash" >&2
  exit 1
fi

if [[ "${1:-}" == "remote-server" ]]; then
  shift
  if [[ ! -f "$REMOTE_SERVER_DIR/server.ts" ]]; then
    echo "Error: expected standalone remote server at: $REMOTE_SERVER_DIR/server.ts" >&2
    exit 1
  fi
  exec "$BUN" "$REMOTE_SERVER_DIR/server.ts" "$@"
fi

if [[ ! -d "$APP/node_modules" ]]; then
  echo "Installing dependencies (one-time)..." >&2
  "$BUN" install --cwd "$APP"
fi

if [[ $# -eq 0 ]]; then
  exec "$BUN" run --cwd "$APP" dev "$PWD"
fi

exec "$BUN" run --cwd "$APP" dev "$@"
